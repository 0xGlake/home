		{"id":"eth-specified-group","type":"group","x":-32,"y":4961,"width":1725,"height":580,"label":"The Standard Specified"},
		{"id":"pol-corollaries-group","type":"group","x":-2508,"y":13745,"width":1669,"height":547,"label":"Key Corollaries"},
		{"id":"eth-culmination-group","type":"group","x":79,"y":8957,"width":1669,"height":534,"label":"Culmination & Bridge to Politics"},
		{"id":"eth-standard-group","type":"group","x":-32,"y":3943,"width":1725,"height":504,"label":"The Standard"},
		{"id":"aes-standard-group","type":"group","x":3626,"y":17322,"width":835,"height":717,"label":"The Standard"},
		{"id":"legend-group","type":"group","x":-1475,"y":-10288,"width":556,"height":1018,"label":"COLOR KEY"},
		{"id":"aes-function-group","type":"group","x":3626,"y":15224,"width":835,"height":648,"label":"The Function"},
		{"id":"pol-opposite-group","type":"group","x":-2091,"y":17229,"width":835,"height":628,"label":"The Opposite"},
		{"id":"pol-system-group","type":"group","x":-2091,"y":16271,"width":835,"height":614,"label":"The System"},
